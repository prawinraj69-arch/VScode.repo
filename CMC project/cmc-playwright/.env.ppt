ENV=ppt
BASE_URL=https://app.powerbi.com
WORKSPACE_NAME=CMC PPT
WORKSPACE_LABEL=PPT

# ── MUST be filled with the real PPT values (cannot be derived) ──────────────
# Get these from the PPT report URL while viewing it in the browser:
#   https://app.powerbi.com/groups/<POWER_BI_GROUP_ID>/reports/<STABILITY_REPORT_ID>/<pageId>
POWER_BI_GROUP_ID=FILL_PPT_WORKSPACE_GUID
STABILITY_REPORT_ID=FILL_PPT_STABILITY_REPORT_GUID

# ── Page (report-section) IDs — copied from SIT ──────────────────────────────
# These are part of the report definition and normally identical across
# environments (P83 was already confirmed identical). Verify against the live
# PPT report URLs; if a page fails to load, replace that one with the PPT value.
STABILITY_HOME_PAGE_ID=b3ed74ac137ae98e16d2
DOC_DASHBOARD_PAGE_ID=90b0cac629eb7de723a1
P81_BATCH_SUMMARY_PAGE_ID=03f67392e07a57c72e8e
P81_PROTOCOL_SUMMARY_PAGE_ID=ReportSection5d7c126b4d3d5c35570f
P83_STABILITY_RESULTS_PAGE_ID=ReportSection18a7ee8355c6a90b9a30
